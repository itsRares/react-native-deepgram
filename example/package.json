{
  "name": "react-native-deepgram-example",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "ios:device": "expo run:ios --device",
    "prebuild": "expo prebuild --clean",
    "pods": "cd ios && pod install && cd ..",
    "start:built": "DEEPGRAM_USE_BUILT=1 expo start --clear",
    "clean": "expo prebuild --clean && rm -rf ios/build android/build .expo node_modules/.cache"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.27",
    "expo-build-properties": "~0.13.3",
    "expo-document-picker": "^12.0.2",
    "expo-file-system": "~18.0.12",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.6",
    "react-native-deepgram": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@react-native/typescript-config": "^0.81.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.2.2"
  }
}
